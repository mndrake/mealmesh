{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run build:data)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm run lint)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(supabase migration:*)",
      "Bash(supabase db:*)",
      "Bash(supabase gen types:*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd app && (npm ci --no-audit --no-fund || npm install --no-audit --no-fund) && npm run build:data"
          }
        ]
      }
    ]
  }
}
