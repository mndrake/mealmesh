{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:data": "node scripts/build-data.mjs",
    "import:recipes": "tsx scripts/import-recipes.ts",
    "generate:recipes": "tsx scripts/generate-recipes.ts",
    "backfill:images": "tsx scripts/backfill-images.ts",
    "predev": "node scripts/build-data.mjs",
    "dev": "vite",
    "prebuild": "node scripts/build-data.mjs",
    "build": "tsc -b && npm run typecheck:functions && vite build",
    "lint": "eslint .",
    "typecheck:functions": "tsc -p tsconfig.functions.json --noEmit",
    "pretest": "node scripts/build-data.mjs",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@supabase/supabase-js": "^2.108.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "gray-matter": "^4.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
